# Copy this file to .env and fill in your values
# DO NOT commit .env to version control — it contains secrets
# ─────────────────────────────────────────────────────────────

# DATA SOURCE: YAHOO | ANGEL | DHAN
DATA_SOURCE=DHAN

POLL_INTERVAL_SECONDS=60

# ─── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Angel One SmartAPI (required when DATA_SOURCE=ANGEL) ─────
#ANGEL_API_KEY=your_angel_api_key_here
#ANGEL_CLIENT_ID=your_angel_client_id_here
#ANGEL_MPIN=your_4_digit_mpin_here
#ANGEL_TOTP_SECRET=your_totp_secret_here

# ─── Dhan API (required when DATA_SOURCE=DHAN) ────────────────
DHAN_ACCESS_TOKEN=your_dhan_access_token_here
DHAN_CLIENT_ID=your_dhan_client_id_here

# ─── Misc ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
CSV_ENABLED=true
RESPECT_MARKET_HOURS=true
WS_RECONNECT_DELAY=5
WS_MAX_RECONNECT_ATTEMPTS=10

# ─── Trending OI ──────────────────────────────────────────
# Number of consecutive polls that must all move in the same direction
# before a "Trending OI" alert fires (default: 3)
TREND_CONSECUTIVE_POLLS=3
# Minimum % OI change per poll to count as a real move, not noise (default: 0.5)
TREND_MIN_OI_CHANGE_PCT=0.5
